---
import { Image } from "astro:assets";
import { projects } from "../data/index";
import { ExternalLink } from "@lucide/astro";

import generadorQr from "../assets/projects/generador-qr.jpg";
import holidayinnDashboard from "../assets/projects/holidayinn-dashboard.jpg";
import holidayinnUsuarios from "../assets/projects/holidayinn-usuarios.jpg";
import portalFinanzas from "../assets/projects/portal-finanzas.jpg";
import simpsonsApi from "../assets/projects/simpsons-api.jpg";

import type { ImageMetadata } from "astro";

const imageMap: Record<string, ImageMetadata> = {
  "/projects/generador-qr.jpg": generadorQr,
  "/projects/holidayinn-dashboard.jpg": holidayinnDashboard,
  "/projects/holidayinn-usuarios.jpg": holidayinnUsuarios,
  "/projects/portal-finanzas.jpg": portalFinanzas,
  "/projects/simpsons-api.jpg": simpsonsApi,
};
---

<section id="projects" class="relative">
  <div class="section-container">
    <!-- Section header -->
    <div class="reveal mb-16">
      <p class="text-sm font-mono mb-2" style="color: var(--color-accent)">
        03. proyectos
      </p>
      <h2 class="section-title">Lo que he construido</h2>
      <p class="section-subtitle">
        Una selección de proyectos que muestran mis habilidades y pasión.
      </p>
    </div>

    <!-- Projects grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        projects.map((project, i) => (
          <article
            class="reveal group relative rounded-2xl overflow-hidden flex flex-col animate-fade-in"
            style={`animation-delay: ${i * 0.1}s; background-color: var(--color-surface); border: 1px solid var(--color-border);`}
          >
            <!-- Gradient top accent on hover -->
            <div
              class="absolute top-0 left-0 h-0.5 w-full opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-10"
              style="background: linear-gradient(90deg, var(--color-accent), #ec4899)"
            />

            <!-- Project image -->
            <div class="relative overflow-hidden h-48 shrink-0">
              <Image
                src={imageMap[project.image]}
                alt={project.title}
                width={600}
                height={400}
                format="webp"
                quality={80}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
              <div
                class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center gap-3"
                style="background: rgba(0,0,0,0.6)"
              >
                {project.github && (
                  <a
                    href={project.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="w-10 h-10 rounded-full flex items-center justify-center bg-white/10 hover:bg-white/20 transition-colors backdrop-blur-sm border border-white/20"
                    aria-label="GitHub"
                  >
                    <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                    </svg>
                  </a>
                )}
                {project.demo && (
                  <a
                    href={project.demo}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="w-10 h-10 rounded-full flex items-center justify-center bg-white/10 hover:bg-white/20 transition-colors backdrop-blur-sm border border-white/20"
                    aria-label="Demo en vivo"
                  >
                    <ExternalLink class="w-5 h-5 text-white" />
                  </a>
                )}
              </div>
            </div>

            <!-- Content -->
            <div class="flex flex-col flex-1 p-5">
              <h3 class="font-semibold mb-2 group-hover:text-purple-500 dark:group-hover:text-purple-400 transition-colors duration-200">
                {project.title}
              </h3>
              <p class="text-sm leading-relaxed mb-4 flex-1" style="color: var(--color-text-muted)">
                {project.description}
              </p>
              <div class="flex flex-wrap gap-1.5 mt-auto">
                {project.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>

              <!-- Links row -->
              {(project.github || project.demo) && (
                <div class="flex gap-3 mt-4 pt-4" style="border-top: 1px solid var(--color-border)">
                  {project.github && (
                    <a
                      href={project.github}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="flex items-center gap-1.5 text-xs font-medium transition-colors duration-200"
                      style="color: var(--color-text-muted)"
                    >
                      <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                      </svg>
                      Código
                    </a>
                  )}
                  {project.demo && (
                    <a
                      href={project.demo}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="flex items-center gap-1.5 text-xs font-medium transition-colors duration-200"
                      style="color: var(--color-accent)"
                    >
                      <ExternalLink class="w-3.5 h-3.5" />
                      Demo en vivo
                    </a>
                  )}
                </div>
              )}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
