---
import { navLinks, personalInfo } from "../data/index";
import { Sun, Moon } from "@lucide/astro";
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div
    class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between"
  >
    <!-- Logo -->
    <a href="#intro" class="flex items-center gap-2 group">
      <img
        src="/migthy-dev.jpg"
        alt="migthy.dev"
        class="w-7 h-7 rounded-lg object-cover opacity-80 group-hover:opacity-100 transition-opacity duration-200"
      />
      <span
        class="text-lg font-bold font-mono tracking-tight transition-colors duration-200"
        style="color: var(--color-accent)"
      >
        migthy<span class="opacity-50">.</span>dev
      </span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-7">
      {
        navLinks.map((link) => (
          <a href={link.href} class="nav-link">
            {link.name}
          </a>
        ))
      }
    </nav>

    <!-- Right controls -->
    <div class="flex items-center gap-3">
      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        aria-label="Cambiar tema"
        class="w-9 h-9 rounded-xl flex items-center justify-center transition-all duration-200 hover:scale-110"
        style="background-color: var(--color-surface-2); border: 1px solid var(--color-border)"
      >
        <Sun id="icon-sun" class="hidden dark:block w-4 h-4" />
        <Moon id="icon-moon" class="block dark:hidden w-4 h-4" />
      </button>

      <!-- Mobile menu button -->
      <button
        id="menu-btn"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="md:hidden w-9 h-9 rounded-xl flex flex-col items-center justify-center gap-1.5"
        style="background-color: var(--color-surface-2); border: 1px solid var(--color-border)"
      >
        <span class="w-4 h-px block" style="background-color: var(--color-text)"></span>
        <span class="w-4 h-px block" style="background-color: var(--color-text)"></span>
        <span class="w-3 h-px block self-start ml-0.5" style="background-color: var(--color-text)"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t"
    style="background-color: var(--color-surface); border-color: var(--color-border)"
  >
    <nav class="flex flex-col px-6 py-4 gap-4">
      {
        navLinks.map((link) => (
          <a href={link.href} class="nav-link py-1 text-base">
            {link.name}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<script>
  // ── Header scroll effect ───────────────────────────────────────────
  const header = document.getElementById("header");
  window.addEventListener("scroll", () => {
    if (window.scrollY > 20) {
      header?.classList.add(
        "backdrop-blur-md",
        "shadow-sm"
      );
      header!.style.backgroundColor = "rgba(var(--color-surface-rgb, 255,255,255), 0.85)";
    } else {
      header?.classList.remove("backdrop-blur-md", "shadow-sm");
      header!.style.backgroundColor = "transparent";
    }
  });

  // ── Theme toggle ───────────────────────────────────────────────────
  const themeBtn = document.getElementById("theme-toggle");
  themeBtn?.addEventListener("click", () => {
    const html = document.documentElement;
    html.classList.toggle("dark");
    localStorage.setItem(
      "theme",
      html.classList.contains("dark") ? "dark" : "light"
    );
  });

  // ── Mobile Menu ────────────────────────────────────────────────────
  const menuBtn = document.getElementById("menu-btn") as HTMLButtonElement | null;
  const mobileMenu = document.getElementById("mobile-menu");

  menuBtn?.addEventListener("click", () => {
    const isOpen = mobileMenu?.classList.toggle("hidden") === false;
    menuBtn.setAttribute("aria-expanded", String(isOpen));
    menuBtn.setAttribute("aria-label", isOpen ? "Cerrar menú" : "Abrir menú");
  });

  document.querySelectorAll("#mobile-menu a").forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu?.classList.add("hidden");
      menuBtn?.setAttribute("aria-expanded", "false");
      menuBtn?.setAttribute("aria-label", "Abrir menú");
    });
  });
</script>
