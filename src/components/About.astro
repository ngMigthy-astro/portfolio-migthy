---
import { ExternalLink, Code, MapPin, Mail } from "@lucide/astro";
import { useTranslations, useData, getLang } from "../i18n/utils";

const t = useTranslations(Astro.currentLocale);
const { personalInfo, aboutStats } = useData(Astro.currentLocale);
const lang = getLang(Astro.currentLocale);
const cvPath = lang === "en" ? "/en/cv" : "/cv";
---

<section id="about" class="relative">
  <div class="section-container">
    <!-- Section header -->
    <div class="reveal mb-16">
      <p class="text-sm font-mono mb-2" style="color: var(--color-accent)">
        {t.about.tag}
      </p>
      <h2 class="section-title">{t.about.title}</h2>
    </div>

    <div class="grid md:grid-cols-2 gap-16 items-center">
      <!-- Left: avatar + stats -->
      <div class="reveal-left">
        <!-- Avatar container -->
        <div class="relative w-fit mx-auto md:mx-0">
          <div
            class="w-64 h-64 rounded-3xl overflow-hidden relative"
            style="border: 2px solid var(--color-border)"
          >
            <!-- Placeholder avatar — reemplaza con tu foto -->
            <div
              class="w-full h-full flex items-center justify-center"
              style="background: linear-gradient(135deg, rgba(124,58,237,0.15) 0%, rgba(236,72,153,0.1) 100%)"
            >
              <Code class="w-20 h-20" style="color: var(--color-accent)" />
            </div>
          </div>
          <!-- Decorative corner -->
          <div
            class="absolute -bottom-4 -right-4 w-20 h-20 rounded-2xl -z-10"
            style="background-color: var(--color-accent); opacity: 0.15"
          >
          </div>
          <div
            class="absolute -top-4 -left-4 w-12 h-12 rounded-xl -z-10"
            style="background-color: var(--color-accent); opacity: 0.1"
          >
          </div>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-2 gap-4 mt-8">
          {
            aboutStats.map((stat) => (
              <div
                class="rounded-2xl p-4 text-center"
                style="background-color: var(--color-surface); border: 1px solid var(--color-border)"
              >
                <p
                  class="text-2xl font-bold mb-1 gradient-text"
                >
                  {stat.value}
                </p>
                <p class="text-xs" style="color: var(--color-text-muted)">
                  {stat.label}
                </p>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Right: content -->
      <div class="reveal space-y-6">
        <p class="text-lg leading-relaxed" style="color: var(--color-text-muted)">
          {personalInfo.bio}
        </p>

        <p class="text-base leading-relaxed" style="color: var(--color-text-muted)">
          {t.about.p2}
        </p>

        <p class="text-base leading-relaxed" style="color: var(--color-text-muted)">
          {t.about.p3}
        </p>

        <!-- Info grid -->
        <div
          class="grid grid-cols-1 gap-3 pt-4 border-t"
          style="border-color: var(--color-border)"
        >
          <div class="flex items-center gap-3">
            <MapPin class="w-5 h-5 shrink-0" style="color: var(--color-accent)" />
            <div>
              <p class="text-xs" style="color: var(--color-text-muted)">{t.about.location}</p>
              <p class="text-sm font-medium">{personalInfo.location}</p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <Mail class="w-5 h-5 shrink-0" style="color: var(--color-accent)" />
            <div>
              <p class="text-xs" style="color: var(--color-text-muted)">{t.about.email}</p>
              <a
                href={`mailto:${personalInfo.email}`}
                class="text-sm font-medium transition-colors duration-200"
                style="color: var(--color-accent)"
              >
                {personalInfo.email}
              </a>
            </div>
          </div>
        </div>

        <a href={cvPath} target="_blank" rel="noopener noreferrer" class="btn-primary w-fit">
          {t.about.viewCV}
          <ExternalLink class="w-4 h-4" />
        </a>
      </div>
    </div>
  </div>
</section>
