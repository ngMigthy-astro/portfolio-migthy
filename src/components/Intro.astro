---
import { ArrowRight, ExternalLink } from "@lucide/astro";
import { useTranslations, useData, getLang } from "../i18n/utils";

const t = useTranslations(Astro.currentLocale);
const { personalInfo, typingWords } = useData(Astro.currentLocale);
const lang = getLang(Astro.currentLocale);
const cvPath = lang === "en" ? "/en/cv" : "/cv";
---

<section
  id="intro"
  class="relative min-h-screen flex items-center overflow-hidden pt-20"
>
  <div
    class="absolute inset-0 opacity-[0.03] dark:opacity-[0.06]"
    style="background-image: linear-gradient(var(--color-text) 1px, transparent 1px), linear-gradient(90deg, var(--color-text) 1px, transparent 1px); background-size: 48px 48px"
  >
  </div>

  <div
    class="absolute top-1/4 right-1/4 w-72 h-72 rounded-full opacity-10 blur-3xl pointer-events-none animate-float"
    style="background: radial-gradient(circle, var(--color-accent) 0%, transparent 70%)"
  >
  </div>

  <div class="section-container relative z-10 w-full">
    <div class="flex flex-col md:flex-row items-center gap-12 md:gap-16">
      <!-- Left: text -->
      <div class="flex-1 max-w-2xl">
      <div
        class="reveal inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-sm font-medium mb-8"
        style="background-color: var(--color-accent-10); border: 1px solid var(--color-accent-20); color: var(--color-accent-light, #a78bfa)"
      >
        <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
        {t.intro.available}
      </div>

      <!-- Main heading -->
      <h1
        class="reveal text-5xl md:text-6xl lg:text-7xl font-bold leading-[1.1] mb-6"
        style="animation-delay: 0.1s"
      >
        {t.intro.greeting}<br />
        <span class="gradient-text">{personalInfo.name}</span>
      </h1>

      <!-- Typing subtitle -->
      <p
        class="reveal text-xl md:text-2xl font-light mb-6 flex items-center gap-2 min-h-7 md:min-h-8"
        style="color: var(--color-text-muted); animation-delay: 0.2s"
      >
        <span id="typed-text" data-words={JSON.stringify(typingWords)}></span>
        <span class="w-0.5 h-6 animate-blink" style="background-color: var(--color-accent)"></span>
      </p>

      <!-- Bio -->
      <p
        class="reveal text-base leading-relaxed mb-10 max-w-xl"
        style="color: var(--color-text-muted); animation-delay: 0.3s"
      >
        {personalInfo.shortBio}
      </p>

      <!-- CTAs -->
      <div
        class="reveal flex flex-wrap gap-4 mb-12"
        style="animation-delay: 0.4s"
      >
        <a href="#contact" class="btn-primary">
          {t.intro.contactMe}
          <ArrowRight class="w-4 h-4" />
        </a>
        <a href={cvPath} target="_blank" rel="noopener noreferrer" class="btn-outline">
          {t.intro.viewCV}
          <ExternalLink class="w-4 h-4" />
        </a>
      </div>

      <!-- Social links -->
      <div
        class="reveal flex items-center gap-4"
        style="animation-delay: 0.5s"
      >
        <a
          href={personalInfo.github}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="social-icon"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
        <a
          href={personalInfo.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="social-icon"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
        <a
          href={personalInfo.twitter}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Twitter / X"
          class="social-icon"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>

        <span
          class="w-12 h-px"
          style="background-color: var(--color-border)"
        ></span>
        <span class="text-xs" style="color: var(--color-text-muted)">
          {personalInfo.location}
        </span>
      </div>
    </div>

      <!-- Right: profile photo -->
      <div class="reveal shrink-0 flex order-first md:order-last items-center justify-center" style="animation-delay: 0.3s">
        <div class="relative">
          <!-- Glow ring -->
          <div
            class="absolute inset-0 rounded-3xl blur-xl opacity-30 animate-pulse"
            style="background: radial-gradient(circle, var(--color-accent) 0%, #ec4899 100%); transform: scale(1.1)"
          ></div>
          <!-- Photo -->
          <div
            class="relative w-40 h-40 md:w-64 md:h-64 lg:w-72 lg:h-72 rounded-3xl overflow-hidden"
            style="border: 2px solid var(--color-border)"
          >
            <img
              src="/hero.jpg"
              alt="Cesar Jaramillo — Full Stack Developer"
              class="w-full h-full object-cover object-top animate-fade-in"
            />
          </div>
          <!-- Decorative dots -->
          <div
            class="absolute -bottom-4 -right-4 w-20 h-20 rounded-2xl -z-10 opacity-20"
            style="background-color: var(--color-accent)"
          ></div>
          <div
            class="absolute -top-4 -left-4 w-12 h-12 rounded-xl -z-10 opacity-15"
            style="background-color: var(--color-accent)"
          ></div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div
      class="reveal absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-40"
      style="animation-delay: 1s"
    >
      <span class="text-xs font-mono" style="color: var(--color-text-muted)">scroll</span>
      <div
        class="w-px h-12 animate-float"
        style="background: linear-gradient(to bottom, var(--color-accent), transparent)"
      ></div>
    </div>
  </div>
</section>

<style>
  .social-icon {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }
  .social-icon:hover {
    background-color: var(--color-accent);
    border-color: var(--color-accent);
    color: white;
    transform: translateY(-3px);
  }
</style>

<script>
  const typed = document.getElementById("typed-text");
  if (typed) {
    const words = JSON.parse(typed.dataset.words || "[]");
    let wIdx = 0, cIdx = 0, deleting = false;

    function type() {
      const word = words[wIdx];
      if (!deleting) {
        typed!.textContent = word.slice(0, ++cIdx);
        if (cIdx === word.length) {
          deleting = true;
          return setTimeout(type, 2000);
        }
      } else {
        typed!.textContent = word.slice(0, --cIdx);
        if (cIdx === 0) {
          deleting = false;
          wIdx = (wIdx + 1) % words.length;
        }
      }
      setTimeout(type, deleting ? 60 : 100);
    }
    type();
  }
</script>
