---
import { personalInfo, contactServices } from "../data/index";
import { ArrowRight, ExternalLink, Send, Check, Mail, Link2 } from "@lucide/astro";
---

<section id="contact" class="relative">
  <div class="section-container">
    <!-- Section header -->
    <div class="reveal mb-16 text-center">
      <p class="text-sm font-mono mb-2" style="color: var(--color-accent)">
        05. contacto
      </p>
      <h2 class="section-title">Hablemos</h2>
      <p class="section-subtitle max-w-lg mx-auto">
        ¿Tienes un proyecto en mente? ¿Quieres colaborar? No dudes en
        escribirme.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-12 items-start max-w-4xl mx-auto">
      <!-- Left: info -->
      <div class="reveal-left space-y-6">
        <div class="card">
          <h3 class="font-semibold mb-4">¿En qué puedo ayudarte?</h3>
          <ul class="space-y-3">
            {
              contactServices.map((item) => (
                <li class="flex items-center gap-2 text-sm" style="color: var(--color-text-muted)">
                  <Check class="w-4 h-4 shrink-0" style="color: var(--color-accent)" />
                  {item}
                </li>
              ))
            }
          </ul>
        </div>

        <!-- Contact info cards -->
        <div class="space-y-3">
          <a
            href={`mailto:${personalInfo.email}`}
            class="card flex items-center gap-4 group cursor-pointer"
            style="text-decoration: none"
          >
            <div
              class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 transition-colors duration-200"
              style="background-color: var(--color-accent-10)"
            >
              <Mail class="w-5 h-5" style="color: var(--color-accent)" />
            </div>
            <div>
              <p class="text-xs mb-0.5" style="color: var(--color-text-muted)">Email</p>
              <p
                class="text-sm font-medium group-hover:underline"
                style="color: var(--color-accent)"
              >
                {personalInfo.email}
              </p>
            </div>
            <ArrowRight class="w-4 h-4 ml-auto opacity-0 group-hover:opacity-100 transition-opacity" style="color: var(--color-text-muted)" />
          </a>

          <a
            href={personalInfo.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="card flex items-center gap-4 group cursor-pointer"
            style="text-decoration: none"
          >
            <div
              class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0"
              style="background-color: var(--color-accent-10)"
            >
              <Link2 class="w-5 h-5" style="color: var(--color-accent)" />
            </div>
            <div>
              <p class="text-xs mb-0.5" style="color: var(--color-text-muted)">LinkedIn</p>
              <p class="text-sm font-medium" style="color: var(--color-accent)">
                Conectar en LinkedIn
              </p>
            </div>
            <ExternalLink class="w-4 h-4 ml-auto opacity-0 group-hover:opacity-100 transition-opacity" style="color: var(--color-text-muted)" />
          </a>
        </div>
      </div>

      <!-- Right: contact form -->
      <div class="reveal">
        <form id="contact-form" class="card space-y-5" novalidate>
          <input type="hidden" name="access_key" value="f31d7ddd-fec9-4776-ad95-9e6cc0692a29" />
          <input type="hidden" name="from_name" value="Portfolio Contact Form" />
          <input type="checkbox" name="botcheck" class="hidden" style="display: none;" />
          <div>
            <label
              for="name"
              class="block text-sm font-medium mb-2"
            >
              Nombre
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="Tu nombre"
              class="form-input w-full"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium mb-2">
              Email
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="tu@email.com"
              class="form-input w-full"
            />
          </div>

          <div>
            <label for="subject" class="block text-sm font-medium mb-2">
              Asunto
            </label>
            <input
              type="text"
              id="subject"
              name="subject"
              placeholder="¿En qué puedo ayudarte?"
              class="form-input w-full"
            />
          </div>

          <div>
            <label for="message" class="block text-sm font-medium mb-2">
              Mensaje
            </label>
            <textarea
              id="message"
              name="message"
              rows="4"
              required
              placeholder="Cuéntame sobre tu proyecto..."
              class="form-input w-full resize-none"
            ></textarea>
          </div>

          <button type="submit" id="submit-btn" class="btn-primary w-full justify-center">
            <span id="btn-default" class="flex items-center gap-2">
              Enviar mensaje
              <Send class="w-4 h-4" />
            </span>
            <span id="btn-loading" class="hidden items-center gap-2">
              <svg class="w-4 h-4 animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 12a9 9 0 1 1-6.219-8.56" stroke-linecap="round"/>
              </svg>
              Enviando...
            </span>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<!-- Toast -->
<div
  id="toast"
  role="alert"
  aria-live="polite"
  class="fixed bottom-6 right-6 z-9999 flex items-start gap-3 px-4 py-3.5 rounded-2xl shadow-2xl max-w-xs w-[calc(100vw-3rem)] sm:w-auto pointer-events-none opacity-0 translate-y-4"
  style="background-color: var(--color-surface); border: 1px solid var(--color-border); transition: opacity 0.3s ease, transform 0.3s ease;"
>
  <div id="toast-icon" class="shrink-0 w-8 h-8 rounded-xl flex items-center justify-center mt-0.5"></div>
  <div class="flex-1 min-w-0">
    <p id="toast-title" class="text-sm font-semibold leading-snug" style="color: var(--color-text)"></p>
    <p id="toast-msg" class="text-xs mt-0.5" style="color: var(--color-text-muted)"></p>
  </div>
  <button
    id="toast-close"
    aria-label="Cerrar notificación"
    class="shrink-0 w-5 h-5 rounded-lg flex items-center justify-center text-xs transition-colors duration-150 cursor-pointer"
    style="color: var(--color-text-muted)"
  >✕</button>
</div>

<style>
  .form-input {
    width: 100%;
    padding: 0.625rem 0.875rem;
    border-radius: 0.75rem;
    font-size: 0.875rem;
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    background-color: var(--color-surface-2);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    font-family: inherit;
  }

  .form-input::placeholder {
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  .form-input:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px var(--color-accent-10);
  }
</style>

<script>
  const contactForm = document.getElementById("contact-form") as HTMLFormElement | null;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement | null;
  const btnDefault = document.getElementById("btn-default");
  const btnLoading = document.getElementById("btn-loading");

  const toast = document.getElementById("toast") as HTMLElement | null;
  const toastIcon = document.getElementById("toast-icon");
  const toastTitle = document.getElementById("toast-title");
  const toastMsg = document.getElementById("toast-msg");
  const toastClose = document.getElementById("toast-close");

  let toastTimer: ReturnType<typeof setTimeout> | null = null;

  function showToast(type: "success" | "error") {
    if (!toast || !toastIcon || !toastTitle || !toastMsg) return;

    if (type === "success") {
      toastIcon.innerHTML = `<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" style="color:#4ade80"><polyline points="20 6 9 17 4 12"/></svg>`;
      toastIcon.style.backgroundColor = "rgba(74,222,128,0.12)";
      toastTitle.textContent = "¡Mensaje enviado!";
      toastMsg.textContent = "Gracias por escribirme, te responderé pronto.";
    } else {
      toastIcon.innerHTML = `<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" style="color:#f87171"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>`;
      toastIcon.style.backgroundColor = "rgba(248,113,113,0.12)";
      toastTitle.textContent = "Error al enviar";
      toastMsg.textContent = "Algo falló. Inténtalo de nuevo o contáctame por email.";
    }

    toast.style.opacity = "1";
    toast.style.transform = "translateY(0)";
    toast.style.pointerEvents = "auto";

    if (toastTimer) clearTimeout(toastTimer);
    toastTimer = setTimeout(hideToast, 5000);
  }

  function hideToast() {
    if (!toast) return;
    toast.style.opacity = "0";
    toast.style.transform = "translateY(1rem)";
    toast.style.pointerEvents = "none";
  }

  toastClose?.addEventListener("click", hideToast);

  contactForm?.addEventListener("submit", async (e) => {
    e.preventDefault();

    if (submitBtn) submitBtn.disabled = true;
    btnDefault?.classList.replace("flex", "hidden");
    btnLoading?.classList.replace("hidden", "flex");

    const data = new FormData(contactForm);

    try {
      const response = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        body: data,
      });
      const result = await response.json();

      if (result.success) {
        showToast("success");
        contactForm.reset();
      } else {
        showToast("error");
      }
    } catch {
      showToast("error");
    } finally {
      if (submitBtn) submitBtn.disabled = false;
      btnLoading?.classList.replace("flex", "hidden");
      btnDefault?.classList.replace("hidden", "flex");
    }
  });
</script>
