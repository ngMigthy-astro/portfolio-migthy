---
import { personalInfo, contactServices } from "../data/index";
import { ArrowRight, ExternalLink, Send, Check, Mail, Link2 } from "@lucide/astro";
---

<section id="contact" class="relative">
  <div class="section-container">
    <!-- Section header -->
    <div class="reveal mb-16 text-center">
      <p class="text-sm font-mono mb-2" style="color: var(--color-accent)">
        05. contacto
      </p>
      <h2 class="section-title">Hablemos</h2>
      <p class="section-subtitle max-w-lg mx-auto">
        ¿Tienes un proyecto en mente? ¿Quieres colaborar? No dudes en
        escribirme.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-12 items-start max-w-4xl mx-auto">
      <!-- Left: info -->
      <div class="reveal-left space-y-6">
        <div class="card">
          <h3 class="font-semibold mb-4">¿En qué puedo ayudarte?</h3>
          <ul class="space-y-3">
            {
              contactServices.map((item) => (
                <li class="flex items-center gap-2 text-sm" style="color: var(--color-text-muted)">
                  <Check class="w-4 h-4 shrink-0" style="color: var(--color-accent)" />
                  {item}
                </li>
              ))
            }
          </ul>
        </div>

        <!-- Contact info cards -->
        <div class="space-y-3">
          <a
            href={`mailto:${personalInfo.email}`}
            class="card flex items-center gap-4 group cursor-pointer"
            style="text-decoration: none"
          >
            <div
              class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 transition-colors duration-200"
              style="background-color: var(--color-accent-10)"
            >
              <Mail class="w-5 h-5" style="color: var(--color-accent)" />
            </div>
            <div>
              <p class="text-xs mb-0.5" style="color: var(--color-text-muted)">Email</p>
              <p
                class="text-sm font-medium group-hover:underline"
                style="color: var(--color-accent)"
              >
                {personalInfo.email}
              </p>
            </div>
            <ArrowRight class="w-4 h-4 ml-auto opacity-0 group-hover:opacity-100 transition-opacity" style="color: var(--color-text-muted)" />
          </a>

          <a
            href={personalInfo.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="card flex items-center gap-4 group cursor-pointer"
            style="text-decoration: none"
          >
            <div
              class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0"
              style="background-color: var(--color-accent-10)"
            >
              <Link2 class="w-5 h-5" style="color: var(--color-accent)" />
            </div>
            <div>
              <p class="text-xs mb-0.5" style="color: var(--color-text-muted)">LinkedIn</p>
              <p class="text-sm font-medium" style="color: var(--color-accent)">
                Conectar en LinkedIn
              </p>
            </div>
            <ExternalLink class="w-4 h-4 ml-auto opacity-0 group-hover:opacity-100 transition-opacity" style="color: var(--color-text-muted)" />
          </a>
        </div>
      </div>

      <!-- Right: contact form -->
      <div class="reveal">
        <form id="contact-form" class="card space-y-5" novalidate>
          <input type="hidden" name="access_key" value="f31d7ddd-fec9-4776-ad95-9e6cc0692a29" />
          <input type="hidden" name="from_name" value="Portfolio Contact Form" />
          <input type="checkbox" name="botcheck" class="hidden" style="display: none;" />
          <div>
            <label
              for="name"
              class="block text-sm font-medium mb-2"
            >
              Nombre
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="Tu nombre"
              class="form-input w-full"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium mb-2">
              Email
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="tu@email.com"
              class="form-input w-full"
            />
          </div>

          <div>
            <label for="subject" class="block text-sm font-medium mb-2">
              Asunto
            </label>
            <input
              type="text"
              id="subject"
              name="subject"
              placeholder="¿En qué puedo ayudarte?"
              class="form-input w-full"
            />
          </div>

          <div>
            <label for="message" class="block text-sm font-medium mb-2">
              Mensaje
            </label>
            <textarea
              id="message"
              name="message"
              rows="4"
              required
              placeholder="Cuéntame sobre tu proyecto..."
              class="form-input w-full resize-none"
            ></textarea>
          </div>

          <p id="form-status" class="hidden text-sm font-medium"></p>

          <button type="submit" class="btn-primary w-full justify-center">
            Enviar mensaje
            <Send class="w-4 h-4" />
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .form-input {
    width: 100%;
    padding: 0.625rem 0.875rem;
    border-radius: 0.75rem;
    font-size: 0.875rem;
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    background-color: var(--color-surface-2);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    font-family: inherit;
  }

  .form-input::placeholder {
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  .form-input:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px var(--color-accent-10);
  }
</style>

<script>
  const contactForm = document.getElementById(
    "contact-form"
  ) as HTMLFormElement | null;
  const formStatus = document.getElementById("form-status");

  contactForm?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const submitBtn = contactForm.querySelector(
      "button[type=submit]"
    ) as HTMLButtonElement;
    submitBtn.disabled = true;
    submitBtn.textContent = "Enviando...";

    const data = new FormData(contactForm);

    // Aquí puedes integrar Formspree, EmailJS, etc.
    // Ejemplo con Formspree:
    // const response = await fetch("https://formspree.io/f/YOUR_ID", {
    //   method: "POST",
    //   body: data,
    //   headers: { Accept: "application/json" },
    // });

    const response = await fetch("https://api.web3forms.com/submit", {
      method: "POST",
      body: data,
    });
    const result = await response.json();

    if (formStatus) {
      if (result.success) {
        formStatus.textContent = "✅ Mensaje enviado. ¡Gracias!";
        formStatus.classList.remove("hidden", "text-red-500");
        formStatus.classList.add("text-green-500");
        contactForm.reset();
      } else {
        formStatus.textContent = "❌ Hubo un error al enviar. Intenta de nuevo.";
        formStatus.classList.remove("hidden", "text-green-500");
        formStatus.classList.add("text-red-500");
      }
    }
    submitBtn.disabled = false;
    submitBtn.textContent = "Enviar mensaje";
  });
</script>
