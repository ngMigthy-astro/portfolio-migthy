---
import WAButton from "@/components/WAButton.astro";
import "../styles/global.css";
import { siteUrl, ogImage, author, jsonLd } from "../data/seo.ts";
import { getLang, getAlternatePath } from "../i18n/utils";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Cesar Jaramillo — Full Stack Developer",
  description = "Portfolio de Cesar Alejandro Jaramillo Ramirez, Full Stack Developer especializado en Angular, Astro y Laravel. Construyo sistemas web modernos, robustos y escalables.",
} = Astro.props;

const lang = getLang(Astro.currentLocale);
const pathname = new URL(Astro.request.url).pathname;
const alternatePath = getAlternatePath(pathname, lang);
const alternateLang = lang === "en" ? "es" : "en";
const ogLocale = lang === "en" ? "en_US" : "es_MX";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    <meta
      name="keywords"
      content="Full Stack Developer, Angular, Astro, Laravel, TypeScript, Tailwind CSS, PHP, MySQL, Firebase, portfolio, web developer, Guanajuato, México"
    />
    <link rel="canonical" href={siteUrl} />
    <meta name="robots" content="index, follow" />

    <!-- Hreflang alternates for SEO -->
    <link rel="alternate" hreflang="es" href={`${siteUrl}${lang === "en" ? alternatePath : pathname}`} />
    <link rel="alternate" hreflang="en" href={`${siteUrl}${lang === "es" ? alternatePath : pathname}`} />
    <link rel="alternate" hreflang="x-default" href={siteUrl} />

    <!-- Open Graph  -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`Portfolio de ${author}`} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content="Cesar Jaramillo — Portfolio" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@C_jaramz" />
    <meta name="twitter:creator" content="@C_jaramz" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={`Portfolio de ${author}`} />

    <!-- Favicon & theme -->
    <link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
    <meta name="theme-color" content="#7c3aed" />

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json" set:html={jsonLd} />

    <!-- Theme initialization -->
    <script is:inline>
      const saved = localStorage.getItem("theme");
      const prefersDark = window.matchMedia(
        "(prefers-color-scheme: dark)",
      ).matches;
      if (saved === "dark" || (!saved && prefersDark)) {
        document.documentElement.classList.add("dark");
      }
    </script>
  </head>
  <body>
    <slot />

    <!-- WhatsApp floating button -->
    <WAButton />

    <!-- Scroll reveal -->
    <script src="../scripts/scroll.ts"></script>
  </body>
</html>
